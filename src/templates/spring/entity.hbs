    public {{pascal moduleName}}() {
    }

    // ==========================================
    // All-Args Constructor
    // ==========================================
    public {{pascal moduleName}}({{#each fields}}{{type}} {{camel name}}{{#unless @last}}, {{/unless}}{{/each}}) {
        {{#each fields}}
        this.{{camel name}} = {{camel name}};
        {{/each}}
    }

    // ==========================================
    // Getters & Setters
    // ==========================================
    {{#each fields}}
    public {{type}} get{{pascal name}}() {
        return this.{{camel name}};
    }

    public void set{{pascal name}}({{type}} {{camel name}}) {
        this.{{camel name}} = {{camel name}};
    }

    {{/each}}
    {{/unless}}
