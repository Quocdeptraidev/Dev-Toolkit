import React, { useState } from 'react';
import { {{hookName}}, {{pascal moduleName}} } from '{{hookImportPath}}';
import { {{tableComponentName}} } from '{{tableImportPath}}';
import { {{formComponentName}} } from '{{formImportPath}}';

export const {{pascal moduleName}}Page: React.FC = () => {
    const { items, loading, error, createItem, updateItem, deleteItem } = {{hookName}}();
    const [editingItem, setEditingItem] = useState<{{pascal moduleName}} | null>(null);
    const [isFormOpen, setIsFormOpen] = useState<boolean>(false);

    const handleCreateClick = () => {
        setEditingItem(null);
        setIsFormOpen(true);
    };

    const handleEditClick = (item: {{pascal moduleName}}) => {
        setEditingItem(item);
        setIsFormOpen(true);
    };

    const handleDeleteClick = async (id: any) => {
        if (window.confirm('Are you sure you want to delete this item?')) {
            try {
                await deleteItem(id);
            } catch (err) {
                console.error('Failed to delete item', err);
            }
        }
    };

    const handleFormSubmit = async (data: any) => {
        try {
            if (editingItem) {
                await updateItem(editingItem.{{camel idName}}, data);
            } else {
                await createItem(data);
            }
            setIsFormOpen(false);
            setEditingItem(null);
        } catch (err) {
            console.error('Failed to submit form', err);
        }
    };

    const handleFormCancel = () => {
        setIsFormOpen(false);
        setEditingItem(null);
    };

    return (
        <div className="{{#if useTailwind}}p-6 max-w-7xl mx-auto{{else}}crud-page{{/if}}">
            <div className="{{#if useTailwind}}flex justify-between items-center mb-6{{else}}crud-header{{/if}}">
                <h2 class="{{#if useTailwind}}text-2xl font-bold text-gray-800{{/if}}">{{label moduleName}} Management</h2>
                <button 
                    className="{{#if useTailwind}}px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-md shadow-sm transition-colors{{else}}btn btn-primary{{/if}}" 
                    onClick={handleCreateClick}
                >
                    Add New
                </button>
            </div>

            {error && (
                <div className="{{#if useTailwind}}p-4 mb-4 text-sm text-red-700 bg-red-100 rounded-lg{{else}}alert alert-danger{{/if}}">
                    {error}
                </div>
            )}

            {loading ? (
                <div className="{{#if useTailwind}}text-center py-10 text-gray-500 font-medium{{else}}loading{{/if}}">Loading...</div>
            ) : (
                <{{tableComponentName}}
                    items={items}
                    onEdit={handleEditClick}
                    onDelete={handleDeleteClick}
                />
            )}

            {isFormOpen && (
                <div className="{{#if useTailwind}}fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center p-4 z-50{{else}}modal-overlay{{/if}}">
                    <div className="{{#if useTailwind}}bg-white rounded-lg shadow-xl max-w-md w-full p-6{{else}}modal-content{{/if}}">
                        <{{formComponentName}}
                            item={editingItem}
                            onSubmit={handleFormSubmit}
                            onCancel={handleFormCancel}
                        />
                    </div>
                </div>
            )}
        </div>
    );
};
