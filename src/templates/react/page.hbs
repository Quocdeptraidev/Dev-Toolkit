import React, { useState } from 'react';
import { use{{pascal moduleName}}, {{pascal moduleName}} } from './hooks/use{{pascal moduleName}}';
import { {{pascal moduleName}}Table } from './components/{{pascal moduleName}}Table';
import { {{pascal moduleName}}Form } from './components/{{pascal moduleName}}Form';

export const {{pascal moduleName}}Page: React.FC = () => {
    const { items, loading, error, createItem, updateItem, deleteItem } = use{{pascal moduleName}}();
    const [editingItem, setEditingItem] = useState<{{pascal moduleName}} | null>(null);
    const [isFormOpen, setIsFormOpen] = useState<boolean>(false);

    const handleCreateClick = () => {
        setEditingItem(null);
        setIsFormOpen(true);
    };

    const handleEditClick = (item: {{pascal moduleName}}) => {
        setEditingItem(item);
        setIsFormOpen(true);
    };

    const handleDeleteClick = async (id: any) => {
        if (window.confirm('Are you sure you want to delete this item?')) {
            try {
                await deleteItem(id);
            } catch (err) {
                console.error('Failed to delete item', err);
            }
        }
    };

    const handleFormSubmit = async (data: any) => {
        try {
            if (editingItem) {
                await updateItem(editingItem.{{camel idName}}, data);
            } else {
                await createItem(data);
            }
            setIsFormOpen(false);
            setEditingItem(null);
        } catch (err) {
            console.error('Failed to submit form', err);
        }
    };

    const handleFormCancel = () => {
        setIsFormOpen(false);
        setEditingItem(null);
    };

    return (
        <div className="crud-page">
            <div className="crud-header">
                <h2>{{label moduleName}} Management</h2>
                <button className="btn btn-primary" onClick={handleCreateClick}>Add New</button>
            </div>

            {error && <div className="alert alert-danger">{error}</div>}

            {loading ? (
                <div className="loading">Loading...</div>
            ) : (
                <{{pascal moduleName}}Table
                    items={items}
                    onEdit={handleEditClick}
                    onDelete={handleDeleteClick}
                />
            )}

            {isFormOpen && (
                <div className="modal-overlay">
                    <div className="modal-content">
                          <{{pascal moduleName}}Form
                              item={editingItem}
                              onSubmit={handleFormSubmit}
                              onCancel={handleFormCancel}
                          />
                    </div>
                </div>
            )}
        </div>
    );
};
