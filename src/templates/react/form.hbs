import React, { useState, useEffect } from 'react';
import { {{pascal moduleName}} } from '{{hookImportPath}}';

interface {{formComponentName}}Props {
    item?: {{pascal moduleName}} | null;
    onSubmit: (data: any) => void;
    onCancel: () => void;
}

export const {{formComponentName}}: React.FC<{{formComponentName}}Props> = ({ item, onSubmit, onCancel }) => {
    const [formData, setFormData] = useState<Partial<{{pascal moduleName}}>>({});

    useEffect(() => {
        if (item) {
            setFormData(item);
        } else {
            setFormData({});
        }
    }, [item]);

    const handleChange = (e: React.ChangeEvent<HTMLInputElement | HTMLSelectElement>) => {
        const { name, value, type } = e.target;
        let parsedValue: any = value;
        if (type === 'checkbox') {
            parsedValue = (e.target as HTMLInputElement).checked;
        } else if (type === 'number') {
            parsedValue = value === '' ? '' : Number(value);
        }
        setFormData((prev) => ({ ...prev, [name]: parsedValue }));
    };

    const handleSubmit = (e: React.FormEvent) => {
        e.preventDefault();
        onSubmit(formData);
    };

    return (
        <form className="{{#if useTailwind}}space-y-4{{else}}custom-form{{/if}}" onSubmit={handleSubmit}>
            <h3 className="{{#if useTailwind}}text-lg font-bold text-gray-900 border-b pb-2 mb-4{{/if}}">
                {item ? 'Edit' : 'Create'} {{pascal moduleName}}
            </h3>
            
            {{#each fields}}
            {{#unless isId}}
            <div className="{{#if ../useTailwind}}flex flex-col{{else}}form-group{{/if}}">
                <label 
                    htmlFor="{{camel name}}" 
                    className="{{#if ../useTailwind}}text-sm font-semibold text-gray-700 mb-1{{/if}}"
                >
                    {{label name}}{{#if required}} *{{/if}}
                </label>
                <input
                    id="{{camel name}}"
                    name="{{camel name}}"
                    type="{{#if (eq type 'number')}}number{{else}}{#if (eq type 'boolean')}}checkbox{{else}}text{{/if}}{{/if}}"
                    value={formData.{{camel name}} !== undefined ? String(formData.{{camel name}}) : ''}
                    onChange={handleChange}
                    required={ {{#if required}}true{{else}}false{{/if}} }
                    className="{{#if ../useTailwind}}mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm border p-2{{else}}form-control{{/if}}"
                />
            </div>
            {{/unless}}
            {{/each}}
            
            <div className="{{#if useTailwind}}flex justify-end gap-3 pt-4 border-t mt-6{{else}}form-actions{{/if}}">
                <button 
                    type="submit" 
                    className="{{#if useTailwind}}px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-md shadow-sm transition-colors{{else}}btn btn-submit{{/if}}"
                >
                    Save
                </button>
                <button 
                    type="button" 
                    className="{{#if useTailwind}}px-4 py-2 bg-white border border-gray-300 text-gray-700 font-medium rounded-md shadow-sm hover:bg-gray-50 transition-colors{{else}}btn btn-cancel{{/if}}" 
                    onClick={onCancel}
                >
                    Cancel
                </button>
            </div>
        </form>
    );
};
