{
  "name": "dev-toolkit",
  "displayName": "Dev Toolkit",
  "description": "Developer Assistant for React, Spring Boot, and Fullstack projects.",
  "version": "0.1.0",
  "publisher": "dev-toolkit",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:dev-toolkit.helloWorld",
    "onCommand:dev-toolkit.utility.generateUUID",
    "onCommand:dev-toolkit.utility.toCamelCase",
    "onCommand:dev-toolkit.utility.toSnakeCase",
    "onCommand:dev-toolkit.utility.toPascalCase",
    "onCommand:dev-toolkit.utility.generateRandomString",
    "onCommand:dev-toolkit.utility.base64Encode",
    "onCommand:dev-toolkit.utility.base64Decode",
    "onCommand:dev-toolkit.utility.jwtDecode",
    "onCommand:dev-toolkit.utility.jsonToTs",
    "onCommand:dev-toolkit.utility.jsonToJavaDto",
    "onCommand:dev-toolkit.crud.generate",
    "onCommand:dev-toolkit.template.init",
    "onCommand:dev-toolkit.project.analyze",
    "onCommand:dev-toolkit.git.generateCommitMessage",
    "onCommand:dev-toolkit.git.generateChangelog",
    "onCommand:dev-toolkit.git.generateReleaseNotes",
    "onCommand:dev-toolkit.git.createBranch"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "dev-toolkit.helloWorld",
        "title": "Dev Toolkit: Hello World"
      },
      {
        "command": "dev-toolkit.utility.generateUUID",
        "title": "Dev Toolkit: Generate UUID"
      },
      {
        "command": "dev-toolkit.utility.toCamelCase",
        "title": "Dev Toolkit: Convert to camelCase"
      },
      {
        "command": "dev-toolkit.utility.toSnakeCase",
        "title": "Dev Toolkit: Convert to snake_case"
      },
      {
        "command": "dev-toolkit.utility.toPascalCase",
        "title": "Dev Toolkit: Convert to PascalCase"
      },
      {
        "command": "dev-toolkit.utility.generateRandomString",
        "title": "Dev Toolkit: Generate Random String"
      },
      {
        "command": "dev-toolkit.utility.base64Decode",
        "title": "Dev Toolkit: Base64 Decode"
      },
      {
        "command": "dev-toolkit.utility.base64Encode",
        "title": "Dev Toolkit: Base64 Encode"
      },
      {
        "command": "dev-toolkit.utility.jwtDecode",
        "title": "Dev Toolkit: Decode JWT Token"
      },
      {
        "command": "dev-toolkit.utility.jsonToTs",
        "title": "Dev Toolkit: Convert JSON to TypeScript Interface"
      },
      {
        "command": "dev-toolkit.utility.jsonToJavaDto",
        "title": "Dev Toolkit: Convert JSON to Java DTO"
      },
      {
        "command": "dev-toolkit.crud.generate",
        "title": "Dev Toolkit: Generate CRUD Module"
      },
      {
        "command": "dev-toolkit.template.init",
        "title": "Dev Toolkit: Initialize Custom Templates"
      },
      {
        "command": "dev-toolkit.project.analyze",
        "title": "Dev Toolkit: Analyze Project"
      },
      {
        "command": "dev-toolkit.git.generateCommitMessage",
        "title": "Dev Toolkit: Generate Commit Message"
      },
      {
        "command": "dev-toolkit.git.generateChangelog",
        "title": "Dev Toolkit: Generate CHANGELOG"
      },
      {
        "command": "dev-toolkit.git.generateReleaseNotes",
        "title": "Dev Toolkit: Generate Release Notes"
      },
      {
        "command": "dev-toolkit.git.createBranch",
        "title": "Dev Toolkit: Create Git Branch"
      }
    ],
    "configuration": {
      "title": "Dev Toolkit",
      "properties": {
        "dev-toolkit.ai.apiKey": {
          "type": "string",
          "default": "",
          "description": "API Key cho Gemini AI Provider (để sử dụng các tính năng thông minh)."
        },
        "dev-toolkit.ai.model": {
          "type": "string",
          "default": "gemini-1.5-flash",
          "description": "Model Gemini sử dụng (ví dụ: gemini-1.5-flash, gemini-2.5-flash)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "dependencies": {
    "handlebars": "^4.7.9"
  },
  "devDependencies": {
    "@types/glob": "^8.0.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "16.x",
    "@types/vscode": "^1.75.0",
    "@typescript-eslint/eslint-plugin": "^5.49.0",
    "@typescript-eslint/parser": "^5.49.0",
    "@vscode/test-electron": "^2.2.3",
    "eslint": "^8.33.0",
    "glob": "^8.1.0",
    "mocha": "^10.2.0",
    "typescript": "^4.9.5"
  }
}