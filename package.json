{
  "name": "dev-toolkit",
  "displayName": "Dev Toolkit",
  "description": "Developer Assistant for React, Spring Boot, and Fullstack projects.",
  "version": "0.1.0",
  "publisher": "dev-toolkit",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:dev-toolkit.helloWorld",
    "onCommand:dev-toolkit.utility.generateUUID",
    "onCommand:dev-toolkit.utility.toCamelCase",
    "onCommand:dev-toolkit.utility.toSnakeCase",
    "onCommand:dev-toolkit.utility.toPascalCase",
    "onCommand:dev-toolkit.utility.generateRandomString",
    "onCommand:dev-toolkit.utility.base64Encode",
    "onCommand:dev-toolkit.utility.base64Decode",
    "onCommand:dev-toolkit.utility.jwtDecode",
    "onCommand:dev-toolkit.utility.jsonToTs",
    "onCommand:dev-toolkit.utility.jsonToJavaDto"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "dev-toolkit.helloWorld",
        "title": "Dev Toolkit: Hello World"
      },
      {
        "command": "dev-toolkit.utility.generateUUID",
        "title": "Dev Toolkit: Generate UUID"
      },
      {
        "command": "dev-toolkit.utility.toCamelCase",
        "title": "Dev Toolkit: Convert to camelCase"
      },
      {
        "command": "dev-toolkit.utility.toSnakeCase",
        "title": "Dev Toolkit: Convert to snake_case"
      },
      {
        "command": "dev-toolkit.utility.toPascalCase",
        "title": "Dev Toolkit: Convert to PascalCase"
      },
      {
        "command": "dev-toolkit.utility.generateRandomString",
        "title": "Dev Toolkit: Generate Random String"
      },
      {
        "command": "dev-toolkit.utility.base64Decode",
        "title": "Dev Toolkit: Base64 Decode"
      },
      {
        "command": "dev-toolkit.utility.base64Encode",
        "title": "Dev Toolkit: Base64 Encode"
      },
      {
        "command": "dev-toolkit.utility.jwtDecode",
        "title": "Dev Toolkit: Decode JWT Token"
      },
      {
        "command": "dev-toolkit.utility.jsonToTs",
        "title": "Dev Toolkit: Convert JSON to TypeScript Interface"
      },
      {
        "command": "dev-toolkit.utility.jsonToJavaDto",
        "title": "Dev Toolkit: Convert JSON to Java DTO"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "@types/glob": "^8.0.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "16.x",
    "@typescript-eslint/eslint-plugin": "^5.49.0",
    "@typescript-eslint/parser": "^5.49.0",
    "eslint": "^8.33.0",
    "glob": "^8.1.0",
    "mocha": "^10.2.0",
    "typescript": "^4.9.5",
    "@vscode/test-electron": "^2.2.3"
  }
}